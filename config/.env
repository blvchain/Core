# Mongo db connection string
# Format: mongodb://[username:password@]host1[:port1][,host2[:port2],...[,hostN[:portN]]][/[database][?options]]
# Read more: https://www.mongodb.com/docs/manual/reference/connection-string/
MONGO_URI=mongodb://localhost:27017/blvchain

# Node URL must starts with "https://" and must be just the main url without any subdomain or path and any "/" at the end!
# Like https://blvchain.org
NODE_URL=http://localhost:3333

# It must be a valid blvchain address
NODE_WALLET=bd1465212ba7bb2c3ed20e02594b1d49
NODE_PRIVKEY=JH gg d
NODE_PUBKEY=localhost
